NODE_ENV=development
PORT=5000

# MySQL Connection
DATABASE_URL="mysql://root:yourpassword@localhost:3306/assetflow"

# JWT
JWT_SECRET=assetflow_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=assetflow_refresh_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
